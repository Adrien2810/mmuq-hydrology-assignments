  {
   "cell_type": "markdown",
   "id": "9492e967",
   "metadata": {},
   "source": [
    "Our parameter vector is given by:\n",
    "0.000000\n",
    "-100.000000\n",
    "0.000000\n",
    "0.000000\n",
    "96.085948\n",
    "621.587668\n",
    "191.547150\n",
